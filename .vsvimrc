" Visual Studio's VsVim with Toggle Comment

" line numbers
set number
set relativenumber

" scroll
set scrolloff=10
set wrap

" tab
set tabstop=4
set softtabstop=4
set shiftwidth=4
set expandtab

" indent
set autoindent

" search
set nohlsearch
set incsearch

" others
set clipboard=unnamed

" keybindings
nnoremap j jzz
nnoremap k kzz
nnoremap { {zz
nnoremap } }zz

vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" VS Comment Toggle
nnoremap gcc :vsc Edit.ToggleComment<CR>
vnoremap gc :vsc Edit.ToggleComment<CR>
